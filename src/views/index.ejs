  <%- include('../views/partials/hero') %>

  <%- include('../views/partials/about') %>

  <%- include('../views/partials/skills') %>

  <%- include('../views/partials/experience') %>

  <%- include('../views/partials/projects') %>

  <%- include('../views/partials/certifications') %>

  <%- include('../views/partials/education') %>

  <%- include('../views/partials/hobbies') %>

