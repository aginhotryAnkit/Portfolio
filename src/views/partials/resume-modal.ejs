<%
  // Extract file ID from stored URL or use it directly
  const resumeRaw = profile.personal && profile.personal.resume_url
    ? profile.personal.resume_url
    : 'https://drive.google.com/file/d/15ti6U5qD73MyDZtWhaRRK4HKMo0ipnbW';

  // Support both full URL and bare file ID
  const resumeIdMatch = resumeRaw.match(/\/d\/([a-zA-Z0-9_-]+)/);
  const resumeFileId = resumeIdMatch ? resumeIdMatch[1] : resumeRaw;

  const resumePreviewUrl  = `https://drive.google.com/file/d/${resumeFileId}/preview`;
  const resumeDownloadUrl = `https://drive.google.com/uc?export=download&id=${resumeFileId}`;
%>
<!-- Resume Modal -->
<div class="resume-modal" id="resumeModal">
  <div class="resume-modal-overlay" id="resumeOverlay"></div>
  <div class="resume-modal-content">
    <div class="resume-modal-header">
      <h3 class="resume-modal-title">
        <i class="fas fa-file-alt"></i>
        My Resume
      </h3>
      <div class="resume-modal-actions">
        <a href="<%= resumeDownloadUrl %>" 
           class="resume-btn-download" 
           download
           target="_blank"
           rel="noopener noreferrer">
          <i class="fas fa-download"></i>
          Download
        </a>
        <button class="resume-btn-close" id="closeResumeBtn" aria-label="Close">
          <i class="fas fa-times"></i>
        </button>
      </div>
    </div>
    <div class="resume-modal-body">
      <div class="resume-loader">
        <i class="fas fa-spinner fa-spin"></i>
        <p>Loading resume...</p>
      </div>
      <iframe 
        src="<%= resumePreviewUrl %>" 
        class="resume-iframe"
        allow="autoplay"
        loading="lazy">
      </iframe>
    </div>
  </div>
</div>

