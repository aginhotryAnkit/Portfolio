<% const p = profile.personal; %>
<footer>
  <div class="footer-content">
    <div class="footer-name"><%= p ? p.name : 'Ankit Agnihotry' %></div>
    <div class="footer-tagline">Backend Developer · Building things that scale</div>
    <div class="footer-socials">
      <% if (p && p.github) { %>
        <a href="<%= p.github %>" target="_blank" class="footer-social"><i class="fab fa-github"></i></a>
      <% } %>
      <% if (p && p.linkedin) { %>
        <a href="<%= p.linkedin %>" target="_blank" class="footer-social"><i class="fab fa-linkedin-in"></i></a>
      <% } %>
      <% if (p && p.email) { %>
        <a href="mailto:<%= p.email %>" class="footer-social"><i class="fas fa-envelope"></i></a>
      <% } %>
    </div>
    <div class="footer-copy">© <%= new Date().getFullYear() %> <%= p ? p.name : 'Ankit Agnihotry' %>. All rights reserved.</div>
  </div>
</footer>
